# ── Sellora Environment Variables (PostgreSQL version) ─────────────
# Copy this file to .env and fill in your actual values

# ── REQUIRED — Flask secret key
SECRET_KEY=change-me-to-a-long-random-string

# ── PostgreSQL Database URL (REQUIRED — replaces database.db)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Local:  postgresql://postgres:yourpassword@localhost:5432/sellora
# Render: get this from your Render PostgreSQL dashboard
# Neon:   get this from neon.tech dashboard
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sellora

# ── Environment
FLASK_DEBUG=false
PORT=5000

# ── Anthropic AI
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Razorpay
# Sandbox.co.in KYC API key (console.sandbox.co.in se lo)
SANDBOX_API_KEY=key_live_xxxxxxxxxxxxxxxxxxxx

RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx        # Live key Razorpay Dashboard se lo
RAZORPAY_KEY_SECRET=your_razorpay_live_secret

# ── Razorpay Payouts (Auto-Settlement ke liye REQUIRED)
# Razorpay Dashboard → Account & Settings → Bank Account Number (15-digit)
RAZORPAY_ACCOUNT_NUMBER=your_razorpay_virtual_account_number
# Razorpay Dashboard → Webhooks → Webhook Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard

# ── Settlement cycle days (default 7 — Meesho jaisa)
SETTLEMENT_DAYS=7

# ── Platform commission %
PLATFORM_COMMISSION=10

# ── Company / Invoice Details
COMPANY_NAME=Sellora
COMPANY_GSTIN=29AXXXXX1234Z5
COMPANY_ADDRESS=123 Main Street, City, State - 560001

# ── Shiprocket
SHIPROCKET_EMAIL=your-email@gmail.com
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_PICKUP_LOCATION=Primary

# ── Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# ── Cloudinary (Image Storage — REQUIRED on Render)
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Render Cron Job Secret (auto-generated by Render, ya khud set karo)
CRON_SECRET=change-me-strong-random-string
